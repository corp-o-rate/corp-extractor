# Statement Extractor Environment Variables

# Model Backend (choose one)
# Option 1: Cerebrium Serverless (production). Deployed from cerebrium/ — see
# cerebrium/README.md. Both endpoint URLs are required for full functionality
# (text extraction + URL extraction). The hostname uses the AWS region the
# app deployed to: api.<provider>.<region>.cerebrium.ai
CEREBRIUM_EXTRACT_URL=https://api.aws.us-east-1.cerebrium.ai/v4/<project-id>/statement-extractor/extract
CEREBRIUM_EXTRACT_URL_URL=https://api.aws.us-east-1.cerebrium.ai/v4/<project-id>/statement-extractor/extract_url
# Cerebrium auth: a service-account token (project-scoped) or a per-app
# inference key from the dashboard, both work as Bearer tokens.
CEREBRIUM_TOKEN=

# Option 2: Local model server (corp-extractor serve, FastAPI on port 8111
# by default — or local-server/server.py on port 8000)
LOCAL_MODEL_URL=http://localhost:8000

# Supabase (for corrections/feedback and result caching)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (for random text generation in the demo)
OPENAI_API_KEY=

# HuggingFace (optional, for inference API fallback / gated model downloads)
HF_TOKEN=
