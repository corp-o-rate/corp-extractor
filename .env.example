# Statement Extractor Environment Variables

# Model Backend (choose one)
# Option 1: Cerebrium Serverless (production). Deployed from cerebrium/ — see
# cerebrium/README.md. Both endpoint URLs are required for full functionality
# (text extraction + URL extraction).
CEREBRIUM_EXTRACT_URL=https://api.cortex.cerebrium.ai/v4/<project-id>/statement-extractor/extract
CEREBRIUM_EXTRACT_URL_URL=https://api.cortex.cerebrium.ai/v4/<project-id>/statement-extractor/extract_url
CEREBRIUM_TOKEN=

# Option 2: Local model server
LOCAL_MODEL_URL=http://localhost:8000

# Supabase (for corrections/feedback and caching)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (for random text generation)
OPENAI_API_KEY=

# HuggingFace (optional, for inference API fallback)
HF_TOKEN=
